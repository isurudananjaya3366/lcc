{
  // ==================================================
  // LankaCommerce Cloud - VS Code Workspace Settings
  // ==================================================

  // ─── Editor Settings ────────────────────────────────────────────────
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.rulers": [88, 120],
  "editor.wordWrap": "off",
  "editor.minimap.enabled": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.suggest.showStatusBar": true,
  "editor.inlineSuggest.enabled": true,
  "editor.formatOnSave": true,
  "editor.trimAutoWhitespace": true,

  // ─── Files Settings ─────────────────────────────────────────────────
  "files.encoding": "utf8",
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.trimFinalNewlines": true,

  // ─── Python Settings ────────────────────────────────────────────────
  "python.defaultInterpreterPath": "${workspaceFolder}/backend/.venv/Scripts/python.exe",
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.tabSize": 4,
    "editor.formatOnSave": true,
    "editor.formatOnType": false,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },

  // Black formatter settings
  "black-formatter.args": [
    "--config",
    "${workspaceFolder}/backend/pyproject.toml"
  ],
  "black-formatter.path": ["black"],

  // Python linting settings (extension-based)
  "flake8.args": ["--config", "${workspaceFolder}/backend/.flake8"],
  "flake8.cwd": "${workspaceFolder}/backend",
  "flake8.enabled": true,

  // mypy settings
  "mypy-type-checker.args": [
    "--config-file",
    "${workspaceFolder}/backend/mypy.ini"
  ],
  "mypy-type-checker.cwd": "${workspaceFolder}/backend",

  // Ruff settings (if using Ruff instead of flake8)
  "ruff.args": ["--config", "${workspaceFolder}/backend/pyproject.toml"],
  "ruff.organizeImports": true,
  "ruff.fixAll": true,

  // ─── TypeScript / JavaScript Settings ───────────────────────────────
  "typescript.preferences.quoteStyle": "single",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.preferences.quoteStyle": "single",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.formatOnSave": true
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.formatOnSave": true
  },

  // ─── JSON / YAML / Markdown / CSS Settings ──────────────────────────
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.formatOnSave": true
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 2,
    "editor.formatOnSave": true
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.wordWrap": "on",
    "files.trimTrailingWhitespace": false
  },

  // ─── ESLint Settings ────────────────────────────────────────────────
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.workingDirectories": ["./frontend"],

  // ─── File Associations ──────────────────────────────────────────────
  "files.associations": {
    "*.env.*": "dotenv",
    "*.env": "dotenv",
    "Dockerfile*": "dockerfile"
  },

  // ─── File Exclusions ───────────────────────────────────────────────
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/*.pyc": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true,
    "**/.venv": true,
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true
  },

  // ─── Search Exclusions ──────────────────────────────────────────────
  "search.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.venv": true,
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true,
    "**/coverage": true,
    "**/htmlcov": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true
  },

  // ─── Terminal Settings ──────────────────────────────────────────────
  "terminal.integrated.defaultProfile.linux": "bash",
  "terminal.integrated.cwd": "${workspaceFolder}",

  // ─── Tailwind CSS Settings ──────────────────────────────────────────
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"]
  ],

  // ─── Docker Settings ───────────────────────────────────────────────
  "docker.defaultRegistryPath": "",

  // ─── Emmet Settings ─────────────────────────────────────────────────
  "emmet.includeLanguages": {
    "typescriptreact": "html",
    "javascriptreact": "html"
  }
}
