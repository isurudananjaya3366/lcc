# =============================================================================
# LankaCommerce Cloud — Backend Environment Variables
# =============================================================================
# Copy this file to .env or .env.local and fill in the values:
#
#   cp .env.example .env          # primary (loaded second, higher priority)
#   cp .env.example .env.local    # alternative (loaded first)
#
# NEVER commit .env or .env.local to version control.
#
# Variable names must match those defined in config/env.py.
# See config/env.py for defaults, casting helpers, and loading order.
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core Settings
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-long-random-string   # REQUIRED in production — use a long random string
DEBUG=True                                             # Boolean: True/False — MUST be False in production
ALLOWED_HOSTS=localhost,127.0.0.1                      # Comma-separated list of hostnames
DJANGO_SETTINGS_MODULE=config.settings.local           # config.settings.{local,production,test}
LOG_LEVEL=DEBUG                                        # DEBUG, INFO, WARNING, ERROR, CRITICAL

# -----------------------------------------------------------------------------
# Database Settings
# -----------------------------------------------------------------------------
# DATABASE_URL is the canonical connection string (used by dj-database-url).
# Individual DB_* vars are used by local.py for granular control.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lankacommerce_dev
DB_ENGINE=django_tenants.postgresql_backend
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lankacommerce_dev
DB_USER=lcc_user
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Redis / Cache Settings
# -----------------------------------------------------------------------------
# URL format: redis://[:password@]host:port/db_number
REDIS_URL=redis://localhost:6379/0                     # General Redis connection
CACHE_URL=redis://localhost:6379/1                     # Django cache backend

# -----------------------------------------------------------------------------
# Celery Settings
# -----------------------------------------------------------------------------
# URL format: redis://host:port/db_number (or amqp:// for RabbitMQ)
CELERY_BROKER_URL=redis://localhost:6379/0             # Message broker
CELERY_RESULT_BACKEND=redis://localhost:6379/0         # Task result storage

# -----------------------------------------------------------------------------
# Multi-Tenancy Settings
# -----------------------------------------------------------------------------
TENANT_MODEL=tenants.Tenant
TENANT_DOMAIN_MODEL=tenants.Domain
PUBLIC_SCHEMA_NAME=public
BASE_TENANT_DOMAIN=localhost

# -----------------------------------------------------------------------------
# Email / SMTP Settings
# -----------------------------------------------------------------------------
# Used by: django.core.mail, notification module, order confirmations
# In local dev, console backend prints to terminal (no SMTP needed).
# In production, use a real SMTP service (Gmail, SendGrid, SES, etc.).
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com                              # SMTP server hostname
EMAIL_PORT=587                                         # Integer: 587 (TLS) or 465 (SSL)
EMAIL_HOST_USER=                                       # SMTP username — SECRET
EMAIL_HOST_PASSWORD=                                   # SMTP password / app password — SECRET
EMAIL_USE_TLS=True                                     # Boolean: True for port 587
DEFAULT_FROM_EMAIL=noreply@lankacommerce.lk            # Sender address for outgoing mail

# -----------------------------------------------------------------------------
# File Storage / AWS S3 Settings
# -----------------------------------------------------------------------------
# Used by: media uploads, product images, document storage
# In local dev, FileSystemStorage writes to MEDIA_ROOT on disk.
# In production, switch to S3 or compatible (MinIO, DigitalOcean Spaces).
STORAGE_BACKEND=local                                  # "local" | "s3" — switch to s3 for production
DEFAULT_FILE_STORAGE=django.core.files.storage.FileSystemStorage
AWS_ACCESS_KEY_ID=                                     # SECRET — IAM access key
AWS_SECRET_ACCESS_KEY=                                 # SECRET — IAM secret key
AWS_STORAGE_BUCKET_NAME=lcc-media-dev                  # S3 bucket name
AWS_PRIVATE_BUCKET_NAME=                               # Separate private bucket (optional)
AWS_PUBLIC_BUCKET_NAME=                                # Separate public bucket (optional)
AWS_S3_REGION_NAME=ap-south-1                          # AWS region (Mumbai — closest to Sri Lanka)
AWS_S3_ENDPOINT_URL=                                   # Custom endpoint for S3-compatible (MinIO, DO Spaces)
AWS_S3_CUSTOM_DOMAIN=                                  # CDN domain (e.g., cdn.lankacommerce.lk)
AWS_DEFAULT_ACL=private                                # Default ACL for uploaded objects
AWS_QUERYSTRING_AUTH=True                               # Boolean: pre-signed URLs
AWS_PRESIGNED_URL_EXPIRY=3600                          # Signed URL expiry in seconds (default: 1 hour)

# -----------------------------------------------------------------------------
# CORS Settings
# -----------------------------------------------------------------------------
# Used by: django-cors-headers middleware
# Comma-separated list of allowed frontend origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000              # Comma-separated origins
CORS_ALLOW_CREDENTIALS=True                            # Boolean: send cookies cross-origin
# CORS_ALLOWED_HEADERS=*                               # Uncomment to customize allowed headers

# -----------------------------------------------------------------------------
# JWT / Token Authentication Settings
# -----------------------------------------------------------------------------
# Used by: djangorestframework-simplejwt (Phase 3)
# Signing key defaults to DJANGO_SECRET_KEY if not set.
# IMPORTANT: Rotate JWT_SIGNING_KEY independently of SECRET_KEY in production.
# JWT_SIGNING_KEY=                                     # SECRET — override for token signing
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30                   # Integer: access token expiry (minutes)
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7                      # Integer: refresh token expiry (days)
JWT_ROTATE_REFRESH_TOKENS=True                         # Boolean: issue new refresh on use
JWT_BLACKLIST_AFTER_ROTATION=True                      # Boolean: blacklist old refresh tokens

# -----------------------------------------------------------------------------
# Sentry — Error Monitoring (optional)
# -----------------------------------------------------------------------------
# Used by: sentry-sdk with DjangoIntegration (production only)
# Leave SENTRY_DSN empty to disable Sentry entirely.
# Environments: local, staging, production
SENTRY_DSN=                                            # SECRET — Sentry project DSN
SENTRY_ENVIRONMENT=local                               # Sentry environment tag
SENTRY_TRACES_SAMPLE_RATE=0.1                          # Float: 0.0 to 1.0

# -----------------------------------------------------------------------------
# Stripe — Payment Integration Settings
# -----------------------------------------------------------------------------
# Used by: payment module, checkout, subscription billing (Phase 6+)
# Use test keys (sk_test_*, pk_test_*) in development.
# IMPORTANT: Never expose secret key in frontend code.
STRIPE_SECRET_KEY=                                     # SECRET — sk_test_... or sk_live_...
STRIPE_PUBLISHABLE_KEY=                                # pk_test_... or pk_live_...
STRIPE_WEBHOOK_SECRET=                                 # SECRET — whsec_... (from Stripe dashboard)
STRIPE_API_VERSION=2024-06-20                          # Pin Stripe API version

# -----------------------------------------------------------------------------
# SMS Provider Settings
# -----------------------------------------------------------------------------
# Used by: OTP verification, order notifications, delivery alerts
# Supported providers: dialog (Dialog Axiata), mobitel, twilio, nexmo
SMS_PROVIDER=                                          # Provider name (e.g., dialog, twilio)
SMS_API_KEY=                                           # SECRET — provider API key
SMS_SENDER_ID=LCC                                      # Sender ID / alphanumeric label

# -----------------------------------------------------------------------------
# AI / OpenAI Settings
# -----------------------------------------------------------------------------
# Used by: product description generation, smart search, analytics (Phase 10)
# Leave OPENAI_API_KEY empty to disable AI features.
OPENAI_API_KEY=                                        # SECRET — sk-... (OpenAI API key)
OPENAI_MODEL=gpt-4o-mini                               # Model identifier
OPENAI_MAX_TOKENS=4096                                 # Integer: max tokens per request

# -----------------------------------------------------------------------------
# Site / App Identity
# -----------------------------------------------------------------------------
# Used by: email templates, notification branding, SEO meta tags
# Override per environment (dev → staging → production).
SITE_NAME=LankaCommerce Cloud                          # Application display name
SITE_URL=http://localhost:3000                         # Base URL (frontend)
SUPPORT_EMAIL=support@lankacommerce.lk                 # Support contact email

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# LOG_LEVEL controls the root logger level.
# Levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Recommended: DEBUG (local), INFO (staging), WARNING (production)
LOG_LEVEL=DEBUG                                        # Root log level

# -----------------------------------------------------------------------------
# Timezone & Localization Settings
# -----------------------------------------------------------------------------
# TIME_ZONE: IANA timezone — Asia/Colombo for Sri Lanka (UTC+5:30)
# LANGUAGE_CODE: Django i18n language code
DEFAULT_CURRENCY=LKR
TIME_ZONE=Asia/Colombo                                 # IANA timezone
LANGUAGE_CODE=en                                       # Default language
SUPPORTED_LANGUAGES=en,si,ta                           # Comma-separated: English, Sinhala, Tamil

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
CSRF_TRUSTED_ORIGINS=http://localhost:3000              # Comma-separated origins
SECURE_SSL_REDIRECT=False                              # Boolean: MUST be True in production
