# ==================================================
# LankaCommerce Cloud - Backend .dockerignore
# ==================================================

# --------------------------------------------------
# Python
# --------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.eggs/
dist/
build/

# --------------------------------------------------
# Testing
# --------------------------------------------------
.coverage
.pytest_cache/
htmlcov/
.tox/
tests/
conftest.py
pytest.ini

# --------------------------------------------------
# Development
# --------------------------------------------------
*.log
*.pot
.mypy_cache/
.dmypy.json
fixtures/
seeds/

# --------------------------------------------------
# Environment
# --------------------------------------------------
.env
.env.*
!.env.example

# --------------------------------------------------
# IDE
# --------------------------------------------------
.idea/
.vscode/
*.swp
*.swo

# --------------------------------------------------
# Documentation
# --------------------------------------------------
docs/
*.md
!README.md

# --------------------------------------------------
# Docker (avoid recursive)
# --------------------------------------------------
Dockerfile*
docker-compose*.yml

# --------------------------------------------------
# CI/CD
# --------------------------------------------------
.github/
.gitlab-ci.yml
Makefile

# --------------------------------------------------
# Media & Static (collected separately)
# --------------------------------------------------
staticfiles/
mediafiles/
media/
