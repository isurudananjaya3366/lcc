# ==================================================
# LankaCommerce Cloud - Git Ignore Patterns
# ==================================================
# Comprehensive ignore patterns for monorepo
# ==================================================

# -------------------------------------------------
# Operating System
# -------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.directory
.Trash-*

# -------------------------------------------------
# Logs and Debugging
# -------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
debug/
logs/

# -------------------------------------------------
# Editor Backup Files
# -------------------------------------------------
*.bak
*.backup
*.tmp
*.temp

# -------------------------------------------------
# Temporary Files
# -------------------------------------------------
tmp/
temp/
.tmp/
.temp/

# -------------------------------------------------
# Python
# -------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
!frontend/lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
.venv/
ENV/
env/
.env.venv/

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytest_cache/

# Type checker caches
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.ruff_cache/

# Jupyter Notebook
.ipynb_checkpoints

# Django
local_settings.py
db.sqlite3
db.sqlite3-journal

# Celery
celerybeat-schedule
celerybeat.pid

# -------------------------------------------------
# Node.js
# -------------------------------------------------
# Dependencies
node_modules/
.npm/
.pnpm-store/
.yarn/
!.yarn/releases
!.yarn/patches
!.yarn/plugins
!.yarn/sdks
!.yarn/versions

# Build outputs
.next/
out/
.nuxt/
.turbo/
.vercel/
.output/

# Cache
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo
next-env.d.ts

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Testing
coverage/
.nyc_output/

# Storybook
storybook-static/

# Playwright
playwright-report/
playwright/.cache/
test-results/

# -------------------------------------------------
# Environment / Secrets
# -------------------------------------------------
# Environment files (contain secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.staging.local
.env.*
.env.*.local

# Keep example files
!.env.example
!.env.template
!.env.sample
!.env.local.example
!.env.docker.example
!.env.development

# Secrets and credentials
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
secrets/
.secrets/
credentials/
.credentials/

# AWS
.aws/
aws-exports.js

# GCP
*.json.enc
service-account*.json

# -------------------------------------------------
# Docker
# -------------------------------------------------
# Docker override files (local customization)
docker-compose.override.yml
docker-compose.local.yml
.docker/

# Docker data volumes
docker-data/
postgres-data/
redis-data/
staticfiles/

# -------------------------------------------------
# IDE / Editors
# -------------------------------------------------
# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
!.vscode/.gitkeep
.history/
*.vsix

# JetBrains IDEs (IntelliJ, PyCharm, WebStorm)
.idea/
*.iml
*.ipr
*.iws
.idea_modules/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*.swn
*.vim
Session.vim
.netrwhist
tags

# Emacs
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# TextMate
*.tmproj
*.tmproject
tmtags

# Notepad++
*.npp
nppBackup/

# -------------------------------------------------
# Databases
# -------------------------------------------------
# SQLite databases
*.sqlite3
*.db
*.sqlite

# Database dumps
*.sql
*.dump
!migrations/*.sql
!docker/postgres/init/*.sql

# -------------------------------------------------
# Media and Uploads
# -------------------------------------------------
media/
uploads/
static/collected/
backend/media/*
!backend/media/.gitkeep
!backend/media/public/
backend/media/public/*
!backend/media/public/.gitkeep

# -------------------------------------------------
# Document Series (development reference)
# -------------------------------------------------
/Document-Series/
