# =============================================================================
# LankaCommerce Cloud — Frontend Environment Variables (Quick Reference)
# =============================================================================
# For the full documented version, see .env.local.example.
#
#   cp .env.local.example .env.local
#
# NEXT_PUBLIC_ prefix → exposed to browser (client-side).
# No prefix           → server-side only.
# =============================================================================

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
API_BASE_URL=http://backend:8000/api/v1
API_TIMEOUT=30000

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=LankaCommerce Cloud
NEXT_PUBLIC_APP_NAME=LCC
NEXT_PUBLIC_SITE_DESCRIPTION=Multi-tenant SaaS ERP for Sri Lankan SMEs

# Authentication
NEXT_PUBLIC_AUTH_COOKIE_NAME=lcc_auth
NEXT_PUBLIC_TOKEN_EXPIRY_BUFFER=60
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_AI_FEATURES=false
NEXT_PUBLIC_ENABLE_WEBSTORE=true
NEXT_PUBLIC_ENABLE_POS=true
NEXT_PUBLIC_ENABLE_OFFLINE=true
NEXT_PUBLIC_DEBUG=false

# Third-Party Services (Public Keys Only)
NEXT_PUBLIC_GA_TRACKING_ID=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_PAYHERE_MERCHANT_ID=
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
NEXT_PUBLIC_MAPS_API_KEY=

# Server-Only Secrets (never exposed to browser)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SENTRY_AUTH_TOKEN=

# Sri Lanka Localization
NEXT_PUBLIC_DEFAULT_LOCALE=en-LK
NEXT_PUBLIC_DEFAULT_TIMEZONE=Asia/Colombo
NEXT_PUBLIC_DEFAULT_CURRENCY=LKR
NEXT_PUBLIC_CURRENCY_SYMBOL=Rs.

# Tenant Configuration
NEXT_PUBLIC_DEFAULT_TENANT=demo
NEXT_PUBLIC_TENANT_PATTERN={tenant}.lankacommerce.lk

# Image / CDN
NEXT_PUBLIC_IMAGE_DOMAIN=cdn.lankacommerce.lk
NEXT_PUBLIC_CLOUDINARY_CLOUD=
