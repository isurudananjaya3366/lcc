{
  "name": "@lankacommerce/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LankaCommerce Cloud - Multi-tenant ERP Frontend",
  "author": "LankaCommerce Team",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/lankacommerce/lankacommerce-cloud.git",
    "directory": "frontend"
  },
  "keywords": [
    "nextjs",
    "erp",
    "dashboard",
    "typescript",
    "react",
    "sri-lanka",
    "pos",
    "multi-tenant"
  ],
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "lint:strict": "next lint --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "clean": "rimraf .next out",
    "analyze": "cross-env ANALYZE=true next build",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "immer": "^10.1.1",
    "lucide-react": "^0.563.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.5",
    "react-hook-form": "^7.58.1",
    "@hookform/resolvers": "^5.1.1",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-popover": "^1.1.14",
    "react-day-picker": "^9.7.0",
    "date-fns": "^4.1.0",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-tooltip": "^1.2.7",
    "cmdk": "^1.1.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-query-devtools": "^5.0.0",
    "sonner": "^2.0.5",
    "@radix-ui/react-progress": "^1.1.7"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@types/node": "20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "autoprefixer": "^10.4.24",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "typescript": "^5.9.3",
    "@commitlint/cli": "^19.8.2",
    "@commitlint/config-conventional": "^19.8.2",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/nextjs": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "storybook": "^8.6.14"
  }
}
