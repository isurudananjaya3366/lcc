# ==================================================
# LankaCommerce Cloud - Frontend .gitattributes
# ==================================================
# Configures Git behavior for line endings, diffs,
# merge strategies, and language detection.
# ==================================================

# Default behavior: auto-detect text files and normalize line endings
* text=auto

# ── Source Code ────────────────────────────────────
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# ── Configuration & Data ──────────────────────────
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.env text eol=lf

# ── Styles ────────────────────────────────────────
*.css text eol=lf
*.scss text eol=lf
*.sass text eol=lf

# ── HTML & Templates ─────────────────────────────
*.html text eol=lf
*.htm text eol=lf
*.svg text eol=lf

# ── Shell Scripts ─────────────────────────────────
*.sh text eol=lf

# ── Images (binary) ──────────────────────────────
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary

# ── Fonts (binary) ───────────────────────────────
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary

# ── Archives (binary) ────────────────────────────
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary

# ── Lock Files ───────────────────────────────────
# Don't show diffs for lock files (too noisy)
pnpm-lock.yaml -diff
pnpm-lock.yaml merge=union
package-lock.json -diff

# ── Language Detection (GitHub) ──────────────────
*.mjs linguist-language=JavaScript
*.cjs linguist-language=JavaScript
*.tsx linguist-language=TypeScript
*.md linguist-documentation
*.generated.* linguist-generated
