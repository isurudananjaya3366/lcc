# LankaCommerce Cloud (LCC) - Environment Template
#
# Copy to `.env` for local development:
#   cp .env.example .env
#
# IMPORTANT:
# - Do NOT commit real secrets.
# - Leave secret values empty here.
# - Docker services use service names (db, redis) instead of localhost

############################################
# Application Settings
############################################
APP_NAME="LankaCommerce Cloud"
APP_ENV=development               # development|staging|production
APP_DEBUG=true
APP_URL=http://localhost:8000

# Sri Lanka defaults
DEFAULT_CURRENCY=LKR
DEFAULT_TIMEZONE=Asia/Colombo
DEFAULT_LOCALE=en-LK
DEFAULT_COUNTRY=LK
TZ=Asia/Colombo

############################################
# Database (PostgreSQL)
############################################
# Docker: use 'db' as host; Local: use 'localhost'
DATABASE_URL=postgres://lcc_user:dev_password@db:5432/lankacommerce

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=lankacommerce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev_password_change_me

############################################
# Redis / Cache
############################################
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

############################################
# Django Settings
############################################
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.local

############################################
# Next.js Settings
############################################
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="LankaCommerce"
NEXT_PUBLIC_APP_URL=http://localhost:3000

############################################
# Authentication / JWT
############################################
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_LIFETIME=30      # minutes
JWT_REFRESH_TOKEN_LIFETIME=7      # days

############################################
# File Storage (S3 / MinIO)
############################################
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=lcc-media-dev
AWS_S3_REGION_NAME=ap-south-1
AWS_S3_ENDPOINT_URL=http://localhost:9000

############################################
# Email
############################################
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@lankacommerce.lk

############################################
# Payment Gateways
############################################
# PayHere (Sri Lanka)
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_SANDBOX=true

# Stripe (optional / global)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

############################################
# WhatsApp / SMS (Sri Lanka)
############################################
WHATSAPP_BUSINESS_TOKEN=
SMS_GATEWAY_API_KEY=

############################################
# Celery
############################################
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_CONCURRENCY=2
CELERY_LOG_LEVEL=info

############################################
# Flower Monitoring
############################################
FLOWER_BASIC_AUTH=admin:admin
