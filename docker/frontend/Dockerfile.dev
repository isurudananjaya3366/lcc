# ==================================================
# LankaCommerce Cloud - Frontend Development Dockerfile
# ==================================================
# Purpose: Development environment with hot reload
# Base: Node.js 20 Alpine
# Package Manager: pnpm
# ==================================================

# Base image - Node.js 20 Alpine for smallest size
FROM node:20-alpine AS development

# Enable corepack for pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# pnpm environment
ENV PNPM_HOME="/pnpm" \
    PATH="$PNPM_HOME:$PATH"

# Set working directory
WORKDIR /app

# Copy package files for dependency installation
COPY package.json pnpm-lock.yaml* pnpm-workspace.yaml* ./

# Install dependencies
# Use --no-frozen-lockfile in dev: lockfile may be updated locally before docker rebuild
RUN pnpm install --no-frozen-lockfile

# Copy application source
COPY . .

# Expose port
EXPOSE 3000

# Start development server
CMD ["pnpm", "dev"]
