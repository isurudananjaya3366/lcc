# =============================================================================
# LankaCommerce Cloud — Docker Development Environment Variables (Template)
# =============================================================================
# Copy this file to .env.docker and customize:
#
#   cp .env.docker.example .env.docker
#
# This file is used by docker-compose.yml via env_file directive.
# Values here are tailored for the Docker network (service names as hosts).
#
# Key Docker differences from local development:
#   - Database host:  'db'      (not 'localhost')
#   - Redis host:     'redis'   (not 'localhost')
#   - Backend host:   'backend' (for server-side calls from frontend)
#   - All services communicate via 'lcc-network' Docker bridge network
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME="LankaCommerce Cloud"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
TZ=Asia/Colombo

# Sri Lanka defaults
DEFAULT_CURRENCY=LKR
DEFAULT_TIMEZONE=Asia/Colombo
DEFAULT_LOCALE=en-LK
DEFAULT_COUNTRY=LK

# -----------------------------------------------------------------------------
# Django / Backend Settings
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=                                     # REQUIRED — generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,0.0.0.0
DJANGO_SETTINGS_MODULE=config.settings.local
DEBUG=True
LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------------
# Database (PostgreSQL via PgBouncer) — Docker service name: pgbouncer
# -----------------------------------------------------------------------------
# Application traffic routes through PgBouncer (port 6432) for connection
# pooling. For direct PostgreSQL access (migrations, psql), use db:5432.
DATABASE_URL=postgres://lcc_user:dev_password_change_me@pgbouncer:6432/lankacommerce
DB_ENGINE=django_tenants.postgresql_backend
DB_HOST=pgbouncer
DB_PORT=6432
DB_NAME=lankacommerce
DB_USER=lcc_user
DB_PASSWORD=dev_password_change_me

# Postgres container init variables
POSTGRES_DB=lankacommerce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev_password_change_me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis / Cache — Docker service name: redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
CACHE_URL=redis://redis:6379/1

# -----------------------------------------------------------------------------
# Celery — Task Queue / Background Processing
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_APP=config.celery:app
CELERY_CONCURRENCY=2
CELERY_LOG_LEVEL=info
CELERY_QUEUES=default,high_priority,low_priority
CELERY_BEAT_SCHEDULER=django_celery_beat.schedulers:DatabaseScheduler

# -----------------------------------------------------------------------------
# Flower — Celery Monitoring
# -----------------------------------------------------------------------------
FLOWER_PORT=5555
FLOWER_BASIC_AUTH=admin:admin

# -----------------------------------------------------------------------------
# Next.js / Frontend Settings
# -----------------------------------------------------------------------------
NODE_ENV=development
WATCHPACK_POLLING=true

# Client-side (browser) variables — NEXT_PUBLIC_ prefix
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=LankaCommerce Cloud
NEXT_PUBLIC_APP_NAME=LCC
NEXT_PUBLIC_SITE_DESCRIPTION=Multi-tenant SaaS ERP for Sri Lankan SMEs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-side (SSR / API routes) — uses Docker network hostname
API_BASE_URL=http://backend:8000/api/v1
API_TIMEOUT=30000

# Authentication
NEXT_PUBLIC_AUTH_COOKIE_NAME=lcc_auth
NEXT_PUBLIC_TOKEN_EXPIRY_BUFFER=60
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                                       # REQUIRED — generate: openssl rand -base64 32

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_AI_FEATURES=false
NEXT_PUBLIC_ENABLE_WEBSTORE=true
NEXT_PUBLIC_ENABLE_POS=true
NEXT_PUBLIC_ENABLE_OFFLINE=true
NEXT_PUBLIC_DEBUG=false

# Sri Lanka Localization
NEXT_PUBLIC_DEFAULT_LOCALE=en-LK
NEXT_PUBLIC_DEFAULT_TIMEZONE=Asia/Colombo
NEXT_PUBLIC_DEFAULT_CURRENCY=LKR
NEXT_PUBLIC_CURRENCY_SYMBOL=Rs.

# Tenant Configuration
NEXT_PUBLIC_DEFAULT_TENANT=demo
NEXT_PUBLIC_TENANT_PATTERN={tenant}.lankacommerce.lk

# Third-Party Services (leave empty for local dev)
NEXT_PUBLIC_GA_TRACKING_ID=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_PAYHERE_MERCHANT_ID=
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=
NEXT_PUBLIC_MAPS_API_KEY=
NEXT_PUBLIC_IMAGE_DOMAIN=cdn.lankacommerce.lk
NEXT_PUBLIC_CLOUDINARY_CLOUD=

# -----------------------------------------------------------------------------
# Multi-Tenancy
# -----------------------------------------------------------------------------
TENANT_MODEL=tenants.Tenant
TENANT_DOMAIN_MODEL=tenants.Domain
PUBLIC_SCHEMA_NAME=public
BASE_TENANT_DOMAIN=localhost

# -----------------------------------------------------------------------------
# Email (console backend for local Docker dev)
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@lankacommerce.lk

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=True

# -----------------------------------------------------------------------------
# JWT / Token Authentication
# -----------------------------------------------------------------------------
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=True
JWT_BLACKLIST_AFTER_ROTATION=True

# -----------------------------------------------------------------------------
# File Storage (local filesystem in Docker dev)
# -----------------------------------------------------------------------------
DEFAULT_FILE_STORAGE=django.core.files.storage.FileSystemStorage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=lcc-media-dev
AWS_S3_REGION_NAME=ap-south-1
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
AWS_DEFAULT_ACL=private
AWS_QUERYSTRING_AUTH=True

# -----------------------------------------------------------------------------
# Sentry (disabled in local Docker dev)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=docker-local
SENTRY_TRACES_SAMPLE_RATE=0.0

# -----------------------------------------------------------------------------
# Stripe (test keys for Docker dev)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2024-06-20

# -----------------------------------------------------------------------------
# SMS / WhatsApp (disabled in local Docker dev)
# -----------------------------------------------------------------------------
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=LCC
WHATSAPP_BUSINESS_TOKEN=
SMS_GATEWAY_API_KEY=

# -----------------------------------------------------------------------------
# AI / OpenAI (disabled in local Docker dev)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# Site Identity
# -----------------------------------------------------------------------------
SITE_NAME=LankaCommerce Cloud
SITE_URL=http://localhost:3000
SUPPORT_EMAIL=support@lankacommerce.lk

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
CSRF_TRUSTED_ORIGINS=http://localhost:3000
SECURE_SSL_REDIRECT=False

# -----------------------------------------------------------------------------
# Timezone & Localization
# -----------------------------------------------------------------------------
TIME_ZONE=Asia/Colombo
LANGUAGE_CODE=en
SUPPORTED_LANGUAGES=en,si,ta

# -----------------------------------------------------------------------------
# Payment Gateways (Sri Lanka)
# -----------------------------------------------------------------------------
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_SANDBOX=true
