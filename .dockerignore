# ==================================================
# LankaCommerce Cloud - Docker Ignore
# ==================================================
# Files and directories to exclude from Docker build context

# --------------------------------------------------
# Git
# --------------------------------------------------
.git
.gitignore
.gitattributes

# --------------------------------------------------
# IDE / Editor
# --------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# --------------------------------------------------
# Python
# --------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.env
.env.*
!.env.example
*.egg-info/
.eggs/
dist/
build/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
.tox/

# --------------------------------------------------
# Node.js
# --------------------------------------------------
node_modules/
.npm
.pnpm-store/
.next/
out/
.turbo/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --------------------------------------------------
# Testing
# --------------------------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/

# --------------------------------------------------
# Documentation
# --------------------------------------------------
docs/
*.md
!README.md
LICENSE

# --------------------------------------------------
# Docker (recursive)
# --------------------------------------------------
docker/
Dockerfile*
docker-compose*.yml
.dockerignore

# --------------------------------------------------
# Misc
# --------------------------------------------------
*.log
*.tmp
*.temp
*.bak
*.backup
Thumbs.db
